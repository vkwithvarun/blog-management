<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/style.css">
<title>DevBlog</title>
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container">
  <%- include('../partials/messages') %>

  <% if (q) { %>
    <p class="text-muted">Search results for "<%= q %>" — <%= articles.length %> found</p>
  <% } %>

  <% if (articles.length === 0) { %>
    <div class="text-center text-muted mt-5">
      <h4>No articles yet</h4>
      <p>Be the first to <a href="/articles/new">write one</a>.</p>
    </div>
  <% } %>

  <% articles.forEach((article) => { %>
    <div class="card mt-3 shadow-sm">
      <div class="card-body">
        <h4 class="card-title"><%= article.title %></h4>
        <div class="card-subtitle text-muted mb-2">
          <%= article.createdAt.toLocaleDateString() %>
        </div>
        <% if (article.tags && article.tags.length) { %>
          <div class="mb-2">
            <% article.tags.forEach((tag) => { %>
              <span class="badge bg-secondary me-1"><%= tag %></span>
            <% }) %>
          </div>
        <% } %>
        <div class="card-text mb-2"><%= article.description %></div>
        <a href="/articles/<%= article.slug %>" class="btn btn-primary btn-sm">Read More</a>
        <% if (currentUser && article.author && article.author.toString() === currentUser.id) { %>
          <a href="/articles/edit/<%= article.id %>" class="btn btn-info btn-sm">Edit</a>
          <form action="/articles/<%= article.id %>?_method=DELETE" method="POST" class="d-inline">
            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
          </form>
        <% } %>
      </div>
    </div>
  <% }) %>

  <% if (totalPages > 1) { %>
    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === page ? 'active' : '' %>">
            <a class="page-link" href="/?page=<%= i %><%= q ? '&q=' + q : '' %>"><%= i %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>
</body>
</html>
