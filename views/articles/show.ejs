<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/style.css">
<title><%= article.title %> · DevBlog</title>
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container">
  <%- include('../partials/messages') %>
  <h1 class="mb-1"><%= article.title %></h1>
  <div class="text-muted mb-2"><%= article.createdAt.toLocaleDateString() %></div>

  <% if (article.tags && article.tags.length) { %>
    <div class="mb-3">
      <% article.tags.forEach((tag) => { %>
        <span class="badge bg-secondary me-1"><%= tag %></span>
      <% }) %>
    </div>
  <% } %>

  <a href="/" class="btn btn-secondary btn-sm">All Articles</a>
  <% if (currentUser && article.author && article.author.toString() === currentUser.id) { %>
    <a href="/articles/edit/<%= article.id %>" class="btn btn-info btn-sm">Edit</a>
    <form action="/articles/<%= article.id %>?_method=DELETE" method="POST" class="d-inline">
      <button type="submit" class="btn btn-danger btn-sm">Delete</button>
    </form>
  <% } %>

  <div class="article-content mt-4">
    <%- article.sanitizedHTML %>
  </div>
</div>
</body>
</html>
